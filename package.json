{
  "name": "claudine",
  "displayName": "Claudine",
  "description": "Kanban board for managing Claude Code conversations",
  "version": "0.1.0",
  "publisher": "claudine",
  "license": "MIT",
  "icon": "resources/icons/claudine.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/salam/claudine"
  },
  "homepage": "https://claudine.tools",
  "bugs": {
    "url": "https://github.com/salam/claudine/issues"
  },
  "keywords": [
    "kanban",
    "claude",
    "claude-code",
    "conversations",
    "project-management",
    "ai",
    "board"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudine.openKanban",
        "title": "%command.openKanban%",
        "category": "Claudine"
      },
      {
        "command": "claudine.refresh",
        "title": "%command.refresh%",
        "category": "Claudine",
        "icon": "$(refresh)"
      },
      {
        "command": "claudine.closeEmptyClaudeTabs",
        "title": "%command.closeEmptyClaudeTabs%",
        "category": "Claudine",
        "icon": "$(clear-all)"
      },
      {
        "command": "claudine.openConversation",
        "title": "%command.openConversation%",
        "category": "Claudine"
      },
      {
        "command": "claudine.searchConversations",
        "title": "%command.searchConversations%",
        "category": "Claudine"
      },
      {
        "command": "claudine.newConversation",
        "title": "%command.newConversation%",
        "category": "Claudine",
        "icon": "$(add)"
      },
      {
        "command": "claudine.moveConversation",
        "title": "%command.moveConversation%",
        "category": "Claudine"
      },
      {
        "command": "claudine.showNeedsInput",
        "title": "%command.showNeedsInput%",
        "category": "Claudine"
      },
      {
        "command": "claudine.showInProgress",
        "title": "%command.showInProgress%",
        "category": "Claudine"
      },
      {
        "command": "claudine.archiveDone",
        "title": "%command.archiveDone%",
        "category": "Claudine"
      },
      {
        "command": "claudine.toggleSummarization",
        "title": "%command.toggleSummarization%",
        "category": "Claudine",
        "icon": "$(sparkle)"
      },
      {
        "command": "claudine.regenerateIcons",
        "title": "%command.regenerateIcons%",
        "category": "Claudine"
      },
      {
        "command": "claudine.openSettings",
        "title": "%command.openSettings%",
        "category": "Claudine"
      },
      {
        "command": "claudine.focusClaude",
        "title": "%command.focusClaude%",
        "category": "Claudine"
      },
      {
        "command": "claudine.togglePlacement",
        "title": "%command.togglePlacement%",
        "category": "Claudine"
      },
      {
        "command": "claudine.exportBoard",
        "title": "%command.exportBoard%",
        "category": "Claudine"
      },
      {
        "command": "claudine.importBoard",
        "title": "%command.importBoard%",
        "category": "Claudine"
      },
      {
        "command": "claudine.showDiagnostics",
        "title": "%command.showDiagnostics%",
        "category": "Claudine"
      },
      {
        "command": "claudine.toggleSearch",
        "title": "%command.toggleSearch%",
        "category": "Claudine",
        "icon": "$(search)"
      },
      {
        "command": "claudine.toggleFilter",
        "title": "%command.toggleFilter%",
        "category": "Claudine",
        "icon": "$(filter)"
      },
      {
        "command": "claudine.toggleCompactView",
        "title": "%command.toggleCompactView%",
        "category": "Claudine",
        "icon": "$(list-flat)"
      },
      {
        "command": "claudine.toggleExpandAll",
        "title": "%command.toggleExpandAll%",
        "category": "Claudine",
        "icon": "$(expand-all)"
      },
      {
        "command": "claudine.toggleArchive",
        "title": "%command.toggleArchive%",
        "category": "Claudine",
        "icon": "$(archive)"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "claudine-panel",
          "title": "🐘 Claudine",
          "icon": "resources/icons/claudine.png"
        }
      ],
      "activitybar": [
        {
          "id": "claudine-sidebar",
          "title": "Claudine",
          "icon": "resources/icons/claudine-activitybar.svg"
        }
      ]
    },
    "views": {
      "claudine-panel": [
        {
          "type": "webview",
          "id": "claudine.kanbanView",
          "name": "🐘 Claudine",
          "when": "config.claudine.viewLocation != 'sidebar'"
        }
      ],
      "claudine-sidebar": [
        {
          "type": "webview",
          "id": "claudine.kanbanViewSidebar",
          "name": "Claudine",
          "when": "config.claudine.viewLocation == 'sidebar'"
        }
      ]
    },
    "configuration": {
      "title": "Claudine",
      "properties": {
        "claudine.imageGenerationApi": {
          "type": "string",
          "enum": [
            "openai",
            "stability",
            "none"
          ],
          "default": "none",
          "description": "%config.imageGenerationApi.description%"
        },
        "claudine.claudeCodePath": {
          "type": "string",
          "default": "~/.claude",
          "description": "%config.claudeCodePath.description%"
        },
        "claudine.enableSummarization": {
          "type": "boolean",
          "default": false,
          "description": "%config.enableSummarization.description%"
        },
        "claudine.viewLocation": {
          "type": "string",
          "enum": [
            "panel",
            "sidebar"
          ],
          "default": "panel",
          "description": "%config.viewLocation.description%"
        },
        "claudine.toolbarLocation": {
          "type": "string",
          "enum": [
            "sidebar",
            "titlebar",
            "both"
          ],
          "default": "sidebar",
          "description": "%config.toolbarLocation.description%"
        },
        "claudine.autoRestartAfterRateLimit": {
          "type": "boolean",
          "default": false,
          "description": "Automatically restart paused tasks when the Claude API rate limit resets"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "claudine.newConversation",
          "when": "(view == claudine.kanbanView || view == claudine.kanbanViewSidebar) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@1"
        },
        {
          "command": "claudine.toggleSearch",
          "when": "(view == claudine.kanbanView || view == claudine.kanbanViewSidebar) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@2"
        },
        {
          "command": "claudine.toggleFilter",
          "when": "(view == claudine.kanbanView || view == claudine.kanbanViewSidebar) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@3"
        },
        {
          "command": "claudine.toggleCompactView",
          "when": "(view == claudine.kanbanView || view == claudine.kanbanViewSidebar) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@4"
        },
        {
          "command": "claudine.toggleExpandAll",
          "when": "(view == claudine.kanbanView || view == claudine.kanbanViewSidebar) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@5"
        },
        {
          "command": "claudine.toggleSummarization",
          "when": "(view == claudine.kanbanView || view == claudine.kanbanViewSidebar) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@6"
        },
        {
          "command": "claudine.refresh",
          "when": "(view == claudine.kanbanView || view == claudine.kanbanViewSidebar) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@7"
        },
        {
          "command": "claudine.closeEmptyClaudeTabs",
          "when": "(view == claudine.kanbanView || view == claudine.kanbanViewSidebar) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "1_actions@1"
        },
        {
          "command": "claudine.toggleArchive",
          "when": "(view == claudine.kanbanView || view == claudine.kanbanViewSidebar) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "1_actions@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudine.openKanban",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "claudine.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "claudine.kanbanView.visible || claudine.kanbanViewSidebar.visible"
      },
      {
        "command": "claudine.searchConversations",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "claudine.kanbanView.visible || claudine.kanbanViewSidebar.visible"
      },
      {
        "command": "claudine.newConversation",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "claudine.kanbanView.visible || claudine.kanbanViewSidebar.visible"
      },
      {
        "command": "claudine.showNeedsInput",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "claudine.kanbanView.visible || claudine.kanbanViewSidebar.visible"
      },
      {
        "command": "claudine.focusClaude",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c"
      }
    ],
    "walkthroughs": [
      {
        "id": "claudine.gettingStarted",
        "title": "Get Started with Claudine",
        "description": "Learn how to use the Claudine kanban board to manage your Claude Code conversations.",
        "steps": [
          {
            "id": "claudine.walkthrough.installClaude",
            "title": "Install Claude Code",
            "description": "Claudine requires the Claude Code extension to discover conversations.\n\n[Open Extensions](command:workbench.extensions.search?%22anthropic.claude-code%22)",
            "media": { "markdown": "resources/walkthrough/install-claude.md" },
            "completionEvents": ["extensionInstalled:anthropic.claude-code"]
          },
          {
            "id": "claudine.walkthrough.findBoard",
            "title": "Open the Board",
            "description": "Open the Claudine kanban board to see your conversations at a glance.\n\n[Open Claudine Board](command:claudine.openKanban)",
            "media": { "markdown": "resources/walkthrough/find-board.md" },
            "completionEvents": ["onCommand:claudine.openKanban"]
          },
          {
            "id": "claudine.walkthrough.startConversation",
            "title": "Start a Conversation",
            "description": "Create your first Claude Code conversation. It will appear on the board automatically.\n\n[New Conversation](command:claudine.newConversation)",
            "media": { "markdown": "resources/walkthrough/start-conversation.md" },
            "completionEvents": ["onCommand:claudine.newConversation"]
          },
          {
            "id": "claudine.walkthrough.keyFeatures",
            "title": "Explore Key Features",
            "description": "Search, filter, drag-and-drop, and keyboard shortcuts to manage your board.\n\n[Search Conversations](command:claudine.searchConversations)",
            "media": { "markdown": "resources/walkthrough/key-features.md" },
            "completionEvents": ["onCommand:claudine.searchConversations"]
          },
          {
            "id": "claudine.walkthrough.agentIntegration",
            "title": "Set Up Agent Integration",
            "description": "Let Claude Code agents control the board automatically.\n\n[Set Up Agent Integration](command:claudine.setupAgentIntegration)",
            "media": { "markdown": "resources/walkthrough/agent-integration.md" },
            "completionEvents": ["onCommand:claudine.setupAgentIntegration"]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package && npm run build:webview",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "compile:check": "tsc -p ./ --noEmit",
    "build:webview": "cd webview && npm run build",
    "dev:webview": "cd webview && npm run dev",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
